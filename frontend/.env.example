# ===========================================
# FRONTEND ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!
# ===========================================

# Clerk Authentication
# Sign up at: https://clerk.com
# Get your publishable key from: https://dashboard.clerk.com/last-active?path=api-keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Backend API URL
# For local development: http://localhost:5000
# For production: https://your-backend.onrender.com (or your API host)
VITE_API_URL=http://localhost:5000

# Socket.IO server URL (optional — defaults to VITE_API_URL)
# VITE_SOCKET_URL=http://localhost:5000

# Python ML services (optional — emotion chatbot, worker analysis)
# VITE_ML_API_URL=http://localhost:8000
