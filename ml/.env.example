# ===========================================
# ML SERVICES ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ===========================================

# OpenRouter API Configuration
# Sign up at: https://openrouter.ai
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_api_key_here

# Model Selection
# Options: openrouter/auto, openai/gpt-4o-mini, meta-llama/llama-3.2-3b-instruct:free
# Using openrouter/auto automatically selects the best available model
OPENROUTER_MODEL=openrouter/auto

# Internal Service URLs
CRAVING_API_URL=http://localhost:8001

# ML API Port
ML_API_PORT=8000
